DATABASE_URL="postgresql://postgres:postgres@localhost:5432/teamtask"
# Required for JWT login (min 16 characters). Generate: openssl rand -base64 32
JWT_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
NODE_ENV="development"

# Comma-separated emails that become platform admins on signup/login
ADMIN_EMAILS="you@company.com"
